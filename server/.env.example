# Copiez en .env (ou définissez ces variables dans votre hébergeur).

# Port d'écoute (défaut 8787).
PORT=8787

# Emplacement du fichier de données (défaut ./data/db.json).
DB_PATH=./data/db.json

# Jeton d'API. Laissez vide pour un accès ouvert (tests locaux).
# En production, mettez une valeur secrète : l'app devra l'envoyer.
API_TOKEN=
